{
  "expo": {
    "name": "conza_frontend",
    "slug": "conza_frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "conzafrontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.nithinp.conza_frontend"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "039e4395-6f52-4ed8-943e-48ff6a3ae3d1"
      }
    }
  }
}
